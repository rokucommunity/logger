{
  "name": "@rokucommunity/logger",
  "version": "0.3.13",
  "description": "A logging library for use in RokuCommunity tools",
  "main": "dist/index.js",
  "scripts": {
    "preversion": "npm run build && npm run lint && npm run test",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "build": "npm run clean && tsc",
    "watch": "npm run clean && tsc --watch",
    "lint": "eslint \"src/**\"",
    "test": "nyc mocha \"src/**/*spec.ts\"",
    "audit": "npm audit || audit-ci --config ./audit-ci.jsonc",
    "package": "npm run build && npm pack"
  },
  "files": [
    "dist/**/!(*.spec.*|*.map)*"
  ],
  "typings": "dist/index.d.ts",
  "author": "RokuCommunity",
  "license": "MIT",
  "devDependencies": {
    "@cspotcode/source-map-support": "^0.7.0",
    "@types/chai": "^4.2.22",
    "@types/fs-extra": "^9.0.13",
    "@types/mocha": "^10.0.10",
    "@types/node": "^16.11.7",
    "@types/sinon": "^10.0.6",
    "@typescript-eslint/eslint-plugin": "^5.3.1",
    "@typescript-eslint/parser": "^5.3.1",
    "audit-ci": "^7.1.0",
    "chai": "^4.3.4",
    "eslint": "^8.2.0",
    "eslint-plugin-no-only-tests": "^2.6.0",
    "fs-extra": "^10.0.0",
    "mocha": "^10.8.2",
    "nyc": "^15.1.0",
    "sinon": "^12.0.1",
    "ts-node": "^10.4.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "repository": "http://github.com/rokucommunity/logger",
  "mocha": {
    "require": [
      "ts-node/register",
      "@cspotcode/source-map-support/register-hook-require"
    ],
    "fullTrace": true,
    "watchExtensions": [
      "ts"
    ]
  },
  "nyc": {
    "include": [
      "src/**/!(*.spec).ts"
    ],
    "extension": [
      ".ts"
    ],
    "require": [
      "ts-node/register",
      "@cspotcode/source-map-support/register-hook-require"
    ],
    "reporter": [
      "text-summary",
      "html",
      "lcovonly"
    ],
    "sourceMap": true,
    "instrument": true,
    "check-coverage": false,
    "lines": 100,
    "statements": 100,
    "functions": 100,
    "branches": 100
  }
}
